DATABASE_URL=jdbc:postgresql://localhost:5432/codex
DATABASE_USERNAME=ved
DATABASE_PASSWORD=admin123
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
ELASTICSEARCH_URIS=http://localhost:9200
ELASTICSEARCH_HEALTH_ENABLED=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_HEALTH_ENABLED=false
SERVER_PORT=8080

# ── Jira ─────────────────────────────────────────────────────────────────────
# Free tier: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_BASE_URL=https://yourorg.atlassian.net
JIRA_EMAIL=you@company.com
JIRA_API_TOKEN=
JIRA_AC_FIELD=customfield_10016

# ── GitHub ────────────────────────────────────────────────────────────────────
# PAT: https://github.com/settings/tokens → Fine-grained, repo:write scope
GITHUB_TOKEN=
GITHUB_OWNER=your-username
GITHUB_REPO=your-target-repo
GITHUB_BASE_BRANCH=main

# ── Code Generator ────────────────────────────────────────────────────────────
CODEGEN_BASE_PACKAGE=com.example.generated

# ── Requirement Analyzer ─────────────────────────────────────────────────────
# Choose provider: rule-based (default, no key needed) | gemini | groq | ollama
ANALYZER_PROVIDER=rule-based
ANALYZER_FALLBACK=true

# Gemini (free): https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq (free): https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Ollama (local, free): https://ollama.com — then: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
